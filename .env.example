# -----------------------------
# PostgreSQL
# -----------------------------
POSTGRES_DB=taskboard_db
POSTGRES_USER=taskboard_user
POSTGRES_PASSWORD= .... # le password sécurisé

# -----------------------------
# Node.js / Application
# -----------------------------
NODE_ENV=production
DB_HOST=postgres
DB_PORT=5432
DB_NAME=${POSTGRES_DB}
DB_USER=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}

# -----------------------------
# JWT / Auth (si utilisé)
# -----------------------------
JWT_SECRET= .... # le secret JWT sécurisé

# -----------------------------
# Autres variables sensibles
# -----------------------------
APP_PORT=3000